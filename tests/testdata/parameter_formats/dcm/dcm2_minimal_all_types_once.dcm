* Derived from publicly available DCM syntax examples
* Sources: muellerj/mat2dcm README + spec files (festwert/festwerteblock/kennlinie/kennfeld)
* Kennlinien: mehrere Laengen; ST/X und WERT teils stark nichtlinear / nicht-aquidistant.
* Kennfelder: verschiedene Rastergroessen; Achsen und Z-Werte nichtlinear.

KONSERVIERUNG_FORMAT 2.0

FESTWERT K_MIN_SCALAR
 LANGNAME "Minimal scalar value"
 EINHEIT V
 VAR K_MIN_SCALAR
 FUNKTION BaseCalibration
 WERT 42.000
END

FESTWERTEBLOCK K_MIN_BLOCK 8
 LANGNAME "Minimal value block"
 EINHEIT A
 VAR K_MIN_BLOCK
 WERT 1.150 1.333 1.611 2.034 2.678 3.658 5.150 7.421
END

KENNLINIE K_MIN_LINE 8
 LANGNAME "Torque over speed"
 EINHEIT Nm
 LANGNAME_X "Engine speed"
 EINHEIT_X rpm
 VAR K_MIN_LINE
 ST/X 0.100 0.850 2.200 3.650 5.050 6.400 8.250 10.700
 WERT 8.031 9.071 13.142 19.855 28.256 37.945 53.528 77.922
END

* Kurve 5 Punkte: ST/X nicht-aquidistant; WERT = 10 + 2*x + 0.3*x^2 + 0.01*x^3
KENNLINIE K_MIN_LINE_NL5 5
 LANGNAME "Short nonlinear torque ramp"
 EINHEIT Nm
 LANGNAME_X "Pedal"
 EINHEIT_X "%"
 VAR K_MIN_LINE_NL5
 ST/X 0.000 0.350 1.200 4.500 18.000
 WERT 10.000000 10.737179 12.849280 25.986250 201.520000
END

* Kurve 11 Punkte: ST/X progressiv; WERT mischung Saettigung + Schwingung
KENNLINIE K_MIN_LINE_NL11 11
 LANGNAME "Wide speed sweep"
 EINHEIT kW
 LANGNAME_X "Shaft speed"
 EINHEIT_X rad/s
 VAR K_MIN_LINE_NL11
 ST/X 0.000 0.200 0.550 1.100 2.000 3.400 5.500 9.000 14.000 22.000 35.000
 WERT 0.000000 1.657853 4.517579 8.908427 15.831253 25.950311 39.463790 56.264674 66.404195 76.251082 105.521293
END

* K_MIN_MAP: 6 x 10 Stuetzstellen; z(x,y) = 0.08*x^3 - 0.05*y^3 + 0.12*x^2*y + 0.07*x*y^2 + 0.15*x*y (kubisch)
KENNFELD K_MIN_MAP 6 10
 LANGNAME "Load map"
 EINHEIT mg/stroke
 LANGNAME_X "Engine speed"
 EINHEIT_X rpm
 LANGNAME_Y "Normalized load"
 EINHEIT_Y "%"
 FUNKTION AirPath
 ST/X 0.000 1.000 2.000 3.000 4.000 5.000
 ST/Y 0.000
 WERT 0.000 0.080 0.640 2.160 5.120 10.000
 ST/Y 1.000
 WERT -0.050 0.370 1.510 3.850 7.870 14.050
 ST/Y 2.000
 WERT -0.400 0.500 2.360 5.660 10.880 18.500
 ST/Y 3.000
 WERT -1.350 0.170 2.890 7.290 13.850 23.050
 ST/Y 4.000
 WERT -3.200 -0.920 2.800 8.440 16.480 27.400
 ST/Y 5.000
 WERT -6.250 -3.070 1.790 8.810 18.470 31.250
 ST/Y 6.000
 WERT -10.800 -6.580 -0.440 8.100 19.520 34.300
 ST/Y 7.000
 WERT -17.150 -11.750 -4.190 6.010 19.330 36.250
 ST/Y 8.000
 WERT -25.600 -18.880 -9.760 2.240 17.600 36.800
 ST/Y 9.000
 WERT -36.450 -28.270 -17.450 -3.510 14.030 35.650
END

* Kennfeld 3x5: nichtlineare Achsen; Z mischt Kreuzterm, Sin, rational
KENNFELD K_MIN_MAP_3X5 5 3
 LANGNAME "Small mixed map"
 EINHEIT bar
 LANGNAME_X "x1"
 EINHEIT_X m
 LANGNAME_Y "x2"
 EINHEIT_Y s
 VAR K_MIN_MAP_3X5
 ST/X 0.000 0.500 1.800 4.200 9.000
 ST/Y -2.000
 WERT -0.719138 -0.594963 -0.185709 0.511569 -0.155954
 ST/Y 0.500
 WERT 0.187012 0.489280 1.343293 2.880521 5.524482
 ST/Y 3.500
 WERT 1.151315 1.512644 2.272317 2.942973 3.109699
END

* Kennfeld 4x7: Achsen mit zunehmenden Abstaenden; Z = sqrt(1+x)*log(1+y)+0.4*sin(x-y)
KENNFELD K_MIN_MAP_4X7 4 7
 LANGNAME "Pressure vs temp and flow"
 EINHEIT kPa
 LANGNAME_X "Flow"
 EINHEIT_X l/min
 LANGNAME_Y "Temperature"
 EINHEIT_Y C
 FUNKTION HydraulicsDemo
 VAR K_MIN_MAP_4X7
 ST/X 0.000 0.700 2.500 8.000
 ST/Y 0.000
 WERT 0.095310 0.381956 0.417698 0.681674
 ST/Y 0.150
 WERT 0.163368 0.500018 0.702053 1.069427
 ST/Y 0.450
 WERT 0.264269 0.670376 1.174845 1.696426
 ST/Y 1.000
 WERT 0.405349 0.849160 1.787036 2.488607
 ST/Y 2.200
 WERT 0.870524 1.157686 2.351832 3.395927
 ST/Y 5.000
 WERT 2.191858 2.724186 3.143610 5.481314
 ST/Y 12.000
 WERT 2.787241 3.735884 4.842977 8.020558
END

* Kennfeld 5x8: x negativ bis positiv; Z mit Potenz und tanh(y)
KENNFELD K_MIN_MAP_5X8 5 8
 LANGNAME "Asymmetric gain surface"
 EINHEIT ""
 LANGNAME_X "Error"
 EINHEIT_X ""
 LANGNAME_Y "Rate"
 EINHEIT_Y ""
 VAR K_MIN_MAP_5X8
 ST/X -1.000 -0.200 0.500 1.500 4.000
 ST/Y 0.000
 WERT -0.195055 -0.762937 -1.329203 -2.223142 -4.784519
 ST/Y 0.250
 WERT -0.192901 -0.756119 -1.318949 -2.209199 -4.768217
 ST/Y 0.600
 WERT -0.189655 -0.738743 -1.293251 -2.178541 -4.758628
 ST/Y 1.200
 WERT -0.170488 -0.660301 -1.176399 -2.029632 -4.597734
 ST/Y 2.500
 WERT 0.239607 0.377182 0.399004 0.287674 0.094578
 ST/Y 4.000
 WERT 1.332165 2.998178 4.387616 6.305114 13.131894
 ST/Y 6.500
 WERT 1.329809 3.489024 5.070953 7.337514 15.169374
 ST/Y 10.000
 WERT 1.205496 3.456427 4.907711 7.730129 15.621918
END

STUETZSTELLENVERTEILUNG K_MIN_AXIS 8
 LANGNAME "Axis support points"
 EINHEIT deg
 LANGNAME_X "Ignition angle"
 EINHEIT_X deg
 VAR K_MIN_AXIS
 ST/X 0.050 1.180 2.730 4.600 7.220 11.050 15.900 22.700
END
